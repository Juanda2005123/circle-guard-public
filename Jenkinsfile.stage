// ============================================================
// Jenkinsfile.stage — Pipeline de CI/CD para el entorno STAGE
// Rama objetivo : release/* o stage
// Namespace K8s : stage
// ============================================================

pipeline {
    agent any

    environment {
        DOCKER_REGISTRY = 'localhost:5000'
        NAMESPACE       = 'stage'
        IMAGE_TAG       = "${env.BUILD_NUMBER}"
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {
        stage('Checkout') {
            steps {
                echo "📥 Descargando código de la rama: ${env.BRANCH_NAME}"
                checkout scm
                sh 'chmod +x gradlew'
            }
        }

        stage('Build & Test') {
            steps {
                echo "🧪 Ejecutando suite de pruebas (unitarias + integración)..."
                sh './gradlew test --no-daemon --continue'
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: '**/build/test-results/**/*.xml'
                    echo "📊 Resultados de pruebas publicados en Jenkins."
                }
                failure {
                    echo "❌ STAGE 2 FALLIDO: Las pruebas no pasaron. Abortando pipeline."
                }
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    echo "🐳 Construyendo imágenes Docker para los 6 microservicios..."

                    def services = [
                        'circleguard-gateway-service',
                        'circleguard-auth-service',
                        'circleguard-identity-service',
                        'circleguard-form-service',
                        'circleguard-notification-service',
                        'circleguard-promotion-service'
                    ]

                    services.each { service ->
                        def imageName = "${env.DOCKER_REGISTRY}/${service}:${env.IMAGE_TAG}"
                        def imageLatest = "${env.DOCKER_REGISTRY}/${service}:latest"

                        echo "  → Building: ${imageName}"
                        sh """
                            docker build \
                                -t ${imageName} \
                                -t ${imageLatest} \
                                -f services/${service}/Dockerfile \
                                .
                        """

                        // Las imágenes se construyen en el Docker local.
                        // Como k8s está en el mismo Docker Desktop y la política es IfNotPresent, 
                        // puede ver las imágenes sin necesidad de kind load o push.
                    }

                    echo "✅ Las 6 imágenes construidas y disponibles en el cluster."
                }
            }
        }

        stage('Deploy Infra') {
            steps {
                script {
                    echo "🏗️  Desplegando infraestructura base en namespace '${env.NAMESPACE}'..."

                    sh 'kubectl apply -f k8s/namespaces.yml'

                    sh '''
                        for file in k8s/infrastructure/*.yml; do
                            echo "  → Aplicando: $file"
                            envsubst < "$file" | kubectl apply -f -
                        done
                    '''

                    echo "⏳ Esperando a que Postgres esté listo..."
                    sh """
                        kubectl rollout status deployment/postgres-deployment \
                            -n ${env.NAMESPACE} \
                            --timeout=120s
                    """
                    echo "✅ Infraestructura desplegada correctamente."
                }
            }
        }

        stage('Deploy Services') {
            steps {
                script {
                    echo "🚀 Desplegando los 6 microservicios en namespace '${env.NAMESPACE}'..."

                    sh '''
                        for file in k8s/templates/*.yml; do
                            echo "  → Aplicando: $file"
                            envsubst < "$file" | kubectl apply -f -
                        done
                    '''

                    def services = [
                        'gateway-service',
                        'identity-service',
                        'auth-service',
                        'form-service',
                        'notification-service',
                        'promotion-service'
                    ]

                    services.each { service ->
                        echo "  → Verificando rollout de ${service}..."
                        sh """
                            kubectl rollout status deployment/${service}-deployment \
                                -n ${env.NAMESPACE} \
                                --timeout=120s
                        """
                    }

                    echo "✅ Todos los microservicios desplegados y en estado Ready."
                }
            }
        }

        stage('E2E & Performance Tests') {
            steps {
                script {
                    echo "🧪 Ejecutando pruebas E2E (REST Assured) y de Rendimiento (Locust)..."
                    sh '''
                        echo "Ejecutando pruebas con REST Assured..."
                        ./gradlew test --tests "*E2E*" || echo "Advertencia: Algunas pruebas E2E fallaron."
                    '''
                    sh '''
                        echo "Ejecutando pruebas de carga con Locust..."
                        # Suponiendo que hay un locustfile.py en la raíz
                        docker run --rm -v \$(pwd)/performance-tests:/mnt/locust locustio/locust -f /mnt/locust/locustfile.py --headless -u 50 -r 10 --run-time 1m --host http://host.docker.internal:30087 || echo "Advertencia: Pruebas de rendimiento finalizadas con errores."
                    '''
                }
            }
        }
    }

    post {
        success {
            echo """
            ============================================
            ✅ PIPELINE STAGE — EXITOSO
            --------------------------------------------
            Namespace  : ${env.NAMESPACE}
            Image Tag  : ${env.IMAGE_TAG}
            Branch     : ${env.BRANCH_NAME}
            Gateway URL: http://localhost:30087
            ============================================
            """
        }
        failure {
            echo """
            ============================================
            ❌ PIPELINE STAGE — FALLIDO
            --------------------------------------------
            Build  : #${env.BUILD_NUMBER}
            Branch : ${env.BRANCH_NAME}
            Revisa los logs del stage marcado en rojo.
            ============================================
            """
        }
        always {
            echo "🔍 Logs del namespace ${env.NAMESPACE}:"
            sh "kubectl get all -n ${env.NAMESPACE} 2>/dev/null || echo 'Namespace no disponible'"
        }
    }
}
